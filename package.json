{
	"name": "scraping-documentacion-regulatoria",
	"version": "1.0.0",
	"description": "Aplicación de scraping diseñada para extraer documentación oficial de webs reguladoras de instituciones. Utiliza Puppeteer para la extracción de datos y Nodemailer para enviar los informes por correo electrónico.",
	"main": "src/index.ts",
	"scripts": {
		"dev": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0  bun --env-file=.env.development --watch run src/index.ts",
		"build": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 bun --env-file=.env.production run tsc",
		"start": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 bun --env-file=.env.production run dist/index.js",
		"test": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 bun --env-file=.env.test run src/test.ts"
	},
	"keywords": [
		"scraping",
		"puppeteer",
		"nodejs",
		"web-scraping",
		"regulatorio",
		"documentacion"
	],
	"author": "Amyssyko",
	"license": "MIT",
	"type": "module",
	"dependencies": {
		"nodemailer": "9.0.1",
		"puppeteer": "25.1.0",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@types/bun": "1.3.14",
		"@types/nodemailer": "8.0.1",
		"cross-env": "10.1.0",
		"tsx": "4.22.4",
		"typescript": "6.0.3"
	},
	"packageManager": "bun@1.3.14"
}
